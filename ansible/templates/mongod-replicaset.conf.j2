# mongod.conf - Shard Server

# for documentation of all options, see:
#   http://docs.mongodb.org/manual/reference/configuration-options/

# where to write logging data.
systemLog:
  destination: file
  logAppend: true
  logRotate: reopen
  path: {{ mongod_log_path }}/mongod.log

{% if enable_audit %}
auditLog:
  destination: file
  format: JSON
  path: {{ audit_log_path }}
  filter: '{{ audit_filter }}'
{% endif %}

# Where and how to store data.
storage:
  dbPath: {{ mongod_path }}
  directoryPerDB: true
# journal:
#   enabled: true
# wiredTiger:
#   engineConfig:
#         directoryForIndexes: true

# how the process runs
processManagement:
  fork: true  # fork and run in background
  pidFilePath: /var/run/mongod.pid  # location of pidfile
  timeZoneInfo: /usr/share/zoneinfo

# network interfaces
net:
  port: {{ mongo_port }}
  bindIp: localhost,{{ hostvars[inventory_hostname]['ansible_default_ipv4']['address'] }}
{% if use_tls %}
  tls:
    mode: requireTLS
    certificateKeyFile: {{ certificateKeyFile }}
    CAFile: {{ CAFile }}
    allowConnectionsWithoutCertificates: true
{% endif %}

security:
  authorization: enabled
{% if use_tls %}
  clusterAuthMode: x509
{% else %}
  keyFile: {{ keyFile_location }}
{% endif %}
{% if keyfile_encryption %}
  enableEncryption: true
  encryptionKeyFile: {{ encryption_keyfile }}
{% elif vault_encryption %}
  enableEncryption: true
  vault:
    serverName: {{ vault_server }}
    port: {{ vault_port }}
    tokenFile: {{ vault_tokenfile }}
    secret: {{ vault_secret }}
    serverCAFile: {{ vault_cafile }}
{% endif %}

operationProfiling:
   slowOpThresholdMs: 200
   mode: all
#   slowOpSampleRate: 0.1
   rateLimit: 100

{% if enable_audit %}
setParameter:
  auditAuthorizationSuccess: true
{% endif %}

replication:
  replSetName: {% if cluster is defined %}{{ cluster }}-{% endif %}{{ hostvars[inventory_hostname].group_names | difference(['replsets', 'shards']) | first }}
